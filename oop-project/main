===== FILE: ./academic/Mark.java =====
import java.io.*;
import java.util.*;

/**
 * 
 */
public class Mark {

	public double att1;
	public double att2;
	public double finalExam;

	public Mark() {
	}

	public double getTotal() {
		return att1 + att2 + finalExam;
	}

}



