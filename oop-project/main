===== FILE: ./users/Employee.java =====
import java.io.*;
import java.util.*;

/**
 * 
 */
public abstract class Employee extends User {

	public double salary;
	public Date hireDate;

	public Employee() {
	}

	public Employee(int id, String username, String password,
		String email, double salary, Date hireDate) {

		super(id, username, password, email);
		this.salary = salary;
		this.hireDate = hireDate;
	}

}



===== FILE: ./users/Student.java =====
import java.io.*;
import java.util.*;

/**
 * 
 */
public class Student extends User {

	public double gpa;
	public int year;
	public int credits;
	public int failedCourses;

	public Student() {
	}

	public Student(int id, String username, String password,
		String email, double gpa, int year, int credits,
		int failedCourses) {

		super(id, username, password, email);
		this.gpa = gpa;
		this.year = year;
		this.credits = credits;
		this.failedCourses = failedCourses;
	}

	public void registerCourse() {

	}

	public void viewTranscript() {

	}

}



===== FILE: ./scheduler/Schedule.java =====
import java.io.*;
import java.util.*;

/**
 * 
 */
public class Schedule {

	public User owner;
	public List<ScheduleEntry> entries;

	public Schedule() {
		entries = new ArrayList<ScheduleEntry>();
	}

	public void addEntry(ScheduleEntry entry) {
		entries.add(entry);
	}

	public void removeEntry(ScheduleEntry entry) {
		entries.remove(entry);
	}

	public List<ScheduleEntry> getEntries() {
		return entries;
	}

}



